generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["impotscouple"]
}

model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([rating])
  @@schema("impotscouple")
}

model Article {
  id                 String    @id @default(uuid()) @db.Uuid
  slug               String    @unique
  title              String
  description        String
  author             String    @default("ImpotsCouple")
  category           String    @default("Fiscalité")
  content            String
  publishedAt        DateTime?
  scheduledPublishAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  isDraft            Boolean   @default(true)

  @@index([slug])
  @@index([publishedAt])
  @@index([scheduledPublishAt])
  @@index([isDraft])
  @@schema("impotscouple")
}
