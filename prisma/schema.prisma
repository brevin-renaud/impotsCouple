generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Simulation {
  id                String   @id @default(uuid()) @db.Uuid
  incomeA           Float
  fraisReelsA       Float    @default(0)
  partsA            Float    @default(0)
  incomeB           Float
  fraisReelsB       Float    @default(0)
  partsB            Float    @default(0)
  children          Int      @default(0)
  gardeAlternee     Boolean  @default(false)
  results           Json
  createdAt         DateTime @default(now())
  donsAssociations  Float    @default(0)
  emploiDomicile    Float    @default(0)
  epargneRetraiteA  Float    @default(0)
  epargneRetraiteB  Float    @default(0)
  fraisGardeEnfants Float    @default(0)
  patrimoineImmoA   Float    @default(0)
  patrimoineImmoB   Float    @default(0)
  pensionVerseeA    Float    @default(0)
  pensionVerseeB    Float    @default(0)

  @@index([createdAt])
}

model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([rating])
}

model Article {
  id                 String    @id @default(uuid()) @db.Uuid
  slug               String    @unique
  title              String
  description        String
  author             String    @default("ImpotsCouple")
  category           String    @default("Fiscalité")
  content            String
  publishedAt        DateTime? // Date de publication effective
  scheduledPublishAt DateTime? // Date de publication programmée à 10H
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  isDraft            Boolean   @default(true)

  @@index([slug])
  @@index([publishedAt])
  @@index([scheduledPublishAt])
  @@index([isDraft])
}

model UserAction {
  id           String   @id @default(uuid()) @db.Uuid
  simulationId String   @db.Uuid
  actionType   String // 'share_link' ou 'generate_pdf'
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([actionType])
  @@index([simulationId])
}
