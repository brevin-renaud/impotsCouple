# ===========================================
# FISCAL COUPLE OPTIMIZER - Variables d'environnement
# ===========================================
# Copie ce fichier en .env et remplis les valeurs

# ===========================================
# DATABASE (Supabase PostgreSQL)
# ===========================================
# URL de connexion Supabase (trouvable dans Settings > Database > Connection string)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:VOTRE_MOT_DE_PASSE@db.VOTRE_PROJECT_REF.supabase.co:5432/postgres"

# URL directe pour les migrations Prisma (même format, utilisé pour les migrations)
DIRECT_URL="postgresql://postgres:VOTRE_MOT_DE_PASSE@db.VOTRE_PROJECT_REF.supabase.co:5432/postgres"

# ===========================================
# APPLICATION
# ===========================================
# URL de base du site (sans slash final)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Environnement (development | production)
NODE_ENV="development"

# ===========================================
# CRON JOBS
# ===========================================
# Secret pour sécuriser les endpoints de cron (purge + publication automatique)
# Génère une clé aléatoire : openssl rand -hex 32
# Utilisé pour /api/cleanup et /api/publish-scheduled
CRON_SECRET="GENERER_UNE_CLE_ALEATOIRE_ICI"
