# ===========================================
# FISCAL COUPLE OPTIMIZER - Variables d'environnement
# ===========================================
# Copie ce fichier en .env et remplis les valeurs

# ===========================================
# DATABASE (Supabase PostgreSQL)
# ===========================================
# URL de connexion Supabase via le Connection Pooler (Transaction mode)
# IMPORTANT: Utiliser le port 6543 (pooler) avec ?pgbouncer=true pour éviter l'erreur "prepared statement already exists"
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-xx-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.VOTRE_PROJECT_REF:VOTRE_MOT_DE_PASSE@aws-0-xx-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL directe pour les migrations Prisma (sans pooler, port 5432)
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-xx-xxx.supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres.VOTRE_PROJECT_REF:VOTRE_MOT_DE_PASSE@aws-0-xx-xxx.supabase.co:5432/postgres"

# ===========================================
# APPLICATION
# ===========================================
# URL de base du site (sans slash final)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Environnement (development | production)
NODE_ENV="development"

# ===========================================
# CRON JOBS
# ===========================================
# Secret pour sécuriser les endpoints de cron (purge + publication automatique)
# Génère une clé aléatoire : openssl rand -hex 32
# Utilisé pour /api/cleanup et /api/publish-scheduled
CRON_SECRET="GENERER_UNE_CLE_ALEATOIRE_ICI"
